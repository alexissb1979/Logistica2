rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function isAdmin() { 
      // Using the user's email from metadata for bootstrap admin
      return isSignedIn() && request.auth.token.email.lower() == 'sepulveda.alexis.a@gmail.com';
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    // --- Collections ---

    // User profiles: users can manage their own, admins can manage all
    match /user_profiles/{uid} {
      allow read: if isSignedIn() && (isOwner(uid) || isAdmin());
      allow create: if isSignedIn() && (isOwner(uid) || isAdmin());
      allow update: if isSignedIn() && (isOwner(uid) || isAdmin());
      allow delete: if isAdmin();
    }

    // Assignments, documents, staging, etc: allow authenticated access
    // (Following user's base intent of "allow all if logged in" but properly structured)
    
    match /assignments/{id} {
      allow read, write: if isSignedIn();
    }

    match /pending_documents/{id} {
      allow read, write: if isSignedIn();
    }

    match /staging_data/{id} {
      allow read, write: if isSignedIn();
    }

    match /routes/{id} {
      allow read, write: if isSignedIn();
    }

    match /drivers/{id} {
      allow read, write: if isSignedIn();
    }

    match /vehicles/{id} {
      allow read, write: if isSignedIn();
    }

    match /manifests/{id} {
      allow read, write: if isSignedIn();
    }

    match /logistics_requests/{id} {
      allow read, write: if isSignedIn();
    }
  }
}
